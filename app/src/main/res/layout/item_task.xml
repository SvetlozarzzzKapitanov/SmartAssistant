<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surfaceColor"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:animateLayoutChanges="true"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/taskTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/iconExpand"
                android:layout_marginEnd="8dp"
                android:textColor="@color/textColorPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="Лекция по ПМУ" />

            <ImageView
                android:id="@+id/iconExpand"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_expand"
                app:tint="@color/textColorSecondary" />
        </RelativeLayout>

        <TextView
            android:id="@+id/taskArrivalTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/textColorPrimary"
            android:textSize="15sp"
            tools:text="11:30 · Днес" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_location"
                app:tint="@color/textColorSecondary" />

            <TextView
                android:id="@+id/taskLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="@color/textColorSecondary"
                android:textSize="14sp"
                tools:text="Технически Университет - София" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/iconTransportMode"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_car"
                app:tint="@color/textColorSecondary" />

            <TextView
                android:id="@+id/taskDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="@color/textColorSecondary"
                android:textSize="12sp"
                tools:text="7.8 km" />
        </LinearLayout>

        <TextView
            android:id="@+id/taskStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Тръгни след 27 мин" />


        <LinearLayout
            android:id="@+id/layoutExpanded"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="14dp"
                android:background="#EAEAEA" />

            <TextView
                android:id="@+id/txtRouteType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_route_chip"
                android:textColor="@color/textColorPrimary"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="GPS" />

            <TextView
                android:id="@+id/txtStartSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:maxLines="2"
                android:ellipsize="end"
                android:textColor="@color/textColorSecondary"
                android:textSize="13sp"
                tools:text="Старт: Technical University" />

            <TextView
                android:id="@+id/txtTimeRange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/textColorPrimary"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="10:03 → 10:30" />

            <TextView
                android:id="@+id/txtRouteWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@android:color/holo_red_light"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="Невъзможен маршрут: предходната задача е твърде късно."
                tools:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavigate"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Стартирай навигация"
                android:textAllCaps="false"
                android:textColor="?attr/colorPrimary" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>